filebeat.modules:
- module: nginx
  access:
    enabled: true
    var.paths: ["/var/log/nginx/access.log"]
  error:
    enabled: true
    var.paths: ["/var/log/nginx/error.log"]

output.elasticsearch:
  hosts: ["http://{{ elasticsearch_host }}:{{ elasticsearch_port }}"]
  # Если отключена безопасность (xpack.security.enabled: false), достаточно так
  # При необходимости можно добавить username/password, но мы отключили security

setup.kibana:
  host: "http://{{ elasticsearch_host }}:5601"   # опционально, для установки дашбордов

# Чтобы не использовать шаблоны индексов по умолчанию, можно явно указать:
# setup.template.name: "nginx"
# setup.template.pattern: "nginx-*"

# Включите логирование самого Filebeat (по желанию)
logging.level: info
logging.to_files: true
logging.files:
  path: /var/log/filebeat